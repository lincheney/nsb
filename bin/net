#!/usr/bin/env -S python3 -SI

import asyncio
import shlex
import sys
import shutil
import os
import json
import socket
import subprocess
from pathlib import Path

LOCALHOST = '127.0.0.1'

def get_free_port():
    with socket.socket() as s:
        s.bind(("", 0))
        return s.getsockname()[1]

class BaseClient:
    def __init__(self):
        self.queue = asyncio.Queue()
        self.transport = None
        self.datagram_counter = 0

    async def recv(self):
        return await self.queue.get()

    def enqueue(self, value):
        try:
            self.queue.put_nowait(value)
        except asyncio.QueueShutDown:
            pass

    def connection_made(self, transport):
        self.transport = transport
    def connection_lost(self, exc):
        self.queue.shutdown()

    # tcp
    def eof_received(self):
        self.enqueue(None)
    def data_received(self, data):
        self.enqueue(data)

    # udp
    def error_received(self, exc):
        pass
    def datagram_received(self, data, addr):
        self.datagram_counter += 1
        self.enqueue(data)

class Forwarder(BaseClient):
    async def forward_to(self, client):
        while True:
            try:
                data = await self.recv()
            except asyncio.QueueShutDown:
                client.transport.close()
                break
            else:
                if data is None:
                    client.transport.write_eof()
                else:
                    client.send(data)

class Server:
    def __init__(self, from_addr, to_addr, start_fn):
        super().__init__()
        self.loop = asyncio.get_running_loop()
        self.from_addr = from_addr
        self.to_addr = to_addr
        self.start_fn = start_fn

    def make_client(self, transport, addr, factory):
        inbound = factory(addr)
        if transport:
            inbound.connection_made(transport)
        proxy = factory(self.to_addr)
        self._forward_task = asyncio.create_task(self.forward(inbound, proxy))
        return inbound

    async def forward(self, inbound, proxy):
        await self.start_fn()
        await self.connect_proxy(proxy)
        forward = asyncio.create_task(self.forward(inbound, proxy))
        backward = asyncio.create_task(self.forward(proxy, inbound))
        try:
            await asyncio.gather(forward, backward)
        finally:
            forward.cancel()
            backward.cancel()
            inbound.transport.close()
            proxy.transport.close()

class TcpServer(Server):
    async def serve(self):
        server = await self.loop.create_server(lambda: self.make_client(None, None, lambda addr: TcpClient()), *self.from_addr)
        async with server:
            await server.serve_forever()

    async def connect_proxy(self, proxy):
        await asyncio.get_running_loop().create_connection(lambda: proxy, *self.to_addr)

class TcpClient(Forwarder):
    def send(self, data):
        self.transport.write(data)


class UdpServer(Server, BaseClient):
    async def serve(self):
        self.clients = {}
        await self.loop.create_datagram_endpoint(lambda: self, local_addr=self.from_addr)
        # do not allow the server transport to be closed
        self.transport.close = lambda: 0
        # mitmproxy has a udp timeout of 20s
        counters = {}
        while True:
            await asyncio.sleep(20)
            for addr, client in self.clients.items():
                if addr not in counters:
                    counters[addr] = client.datagram_counter
                elif counters[addr] == client.datagram_counter:
                    # counter hasn't changed, close it
                    client.connection_lost(None)
            for addr in counters.keys() - self.clients.keys():
                counters.pop(addr)

    def datagram_received(self, data, addr):
        if addr not in self.clients:
            self.clients[addr] = self.make_client(self.transport, addr)
        self.clients[addr].datagram_received(data, addr)

    def make_client(self, transport, addr):
        return super().make_client(transport, addr, UdpClient)

    async def connect_proxy(self, proxy):
        await self.loop.create_datagram_endpoint(lambda: proxy, remote_addr=self.to_addr)

    async def forward(self, inbound, proxy):
        try:
            await super().forward(inbound, proxy)
        finally:
            self.clients.pop(inbound.addr, None)

class UdpClient(Forwarder):
    def __init__(self, addr):
        super().__init__()
        self.addr = addr

    def send(self, data):
        self.datagram_counter += 1
        self.transport.sendto(data, self.addr)


class Handler:
    def __init__(self, args, extras):
        self.args = args
        self.extras = extras
        self.mitm = None

        self.dns_port = get_free_port()
        self.wg_port = get_free_port()

        self.tap_iface = 'eth0'
        self.wg_iface = 'eth1'
        self.tap_subnet = '169.254.2.1/32'
        self.host_ip = '192.168.1.2'
        self.wg_ip = '192.168.2.2'
        self.wg_subnet = f'{self.wg_ip}/24'
        self.wg_conf = Path('~/.mitmproxy/wireguard.conf').expanduser()

    async def start_pasta(self):
        command = ' '.join(map(shlex.quote, self.extras))
        if ld_preload := os.environ.pop('LD_PRELOAD', None):
            command = f'/usr/bin/env LD_PRELOAD={shlex.quote(ld_preload)} {command}'

        wg_conf = json.loads(self.wg_conf.read_text())
        client_key = wg_conf['client_key']
        # i could do async but this is just easier
        server_key = subprocess.check_output(['wg', 'pubkey'], input=wg_conf['server_key'], text=True).strip('\n')
        path = subprocess.check_output(['/usr/bin/getconf', 'PATH'], text=True).strip('\n')

        script_sh = f'''
set -eu -o pipefail
# set up wireguard
ip link add dev {self.wg_iface} type wireguard
ip address add dev {self.wg_iface} {self.wg_subnet}
wg set {self.wg_iface} private-key <(printf %s "$__wg_client_key") peer "$__wg_server_key" allowed-ips 0.0.0.0/0 endpoint {self.host_ip}:{self.wg_port}
unset __wg_client_key __wg_server_key
ip link set up dev {self.wg_iface}

# route everything through wireguard
ip route show | grep -F 'dev {self.tap_iface}' | cut -d' ' -f1 | xargs -n1 ip route del
ip route add default via {self.wg_ip} dev {self.wg_iface}
ip route add {self.host_ip}/32 dev {self.tap_iface}
# drop everything else
iptables -A OUTPUT -p udp -d {self.host_ip} --dport {self.wg_port} -o {self.tap_iface} -j ACCEPT
for cmd in iptables ip6tables; do
    "$cmd" -A OUTPUT -o {self.tap_iface} -j DROP
    "$cmd" -A OUTPUT -p udp -o {self.wg_iface} -j ACCEPT
    "$cmd" -A OUTPUT -p tcp -o {self.wg_iface} -j ACCEPT
    "$cmd" -A OUTPUT -o {self.wg_iface} -j DROP
done

mount -t tmpfs -o size=10M tmpfs /tmp
# override some files
echo nameserver {LOCALHOST} > /tmp/resolv.conf
cat /etc/ssl/certs/ca-certificates.crt ~/.mitmproxy/mitmproxy-ca-cert.pem > /tmp/certs
[[ -e /etc ]] || mount -t tmpfs -o size=100M tmpfs /etc
mount --bind /tmp/resolv.conf /etc/resolv.conf -o ro
mount --bind /tmp/certs /etc/ssl/certs/ca-certificates.crt -o ro
umount /tmp

# drop net admin and reset user
setpriv --bounding-set -net_admin -- \\
unshare --map-user {os.geteuid()} --map-group {os.getegid()} -- \\
{command}
'''

        return await asyncio.create_subprocess_exec(
            shutil.which('pasta', path=path),
            '--ipv4-only',
            '--address', self.tap_subnet.partition('/')[0],
            '--netmask', self.tap_subnet.partition('/')[2],
            '-T', f'53:{self.dns_port}',
            '-U', f'53:{self.dns_port}',
            #  '-t', 'auto',
            #  '-u', 'auto',
            '-I', self.tap_iface,
            '--map-host-loopback', self.host_ip,
            '--config-net',
            'bash', '-c', script_sh,

            env={
                '__wg_server_key': server_key,
                '__wg_client_key': client_key,
                **{k: v for k, v in os.environ.items() if k not in {'LD_PRELOAD'}},
            }
        )

    async def _start_mitmproxy(self):
        proc = await asyncio.create_subprocess_exec(
            'mitmdump',
            '--mode', f'wireguard@{LOCALHOST}:{self.mitm_wg_port}',
            '--mode', f'dns@{LOCALHOST}:{self.mitm_dns_port}',
            '--show-ignored-hosts',
            #  '--showhost',
            *self.args,
        )

        # wait for the dns to be up
        # for udp i don't know when the server is actually up
        # which means any request we send too early will disappear
        # and will have to wait for timeout+retry
        # its faster to hold and send it only once we know its working

        # i swear this works
        query = b'\x00\x00\x01\x00\x00\x01\x00\x00\x00\x00\x00\x00' + b'\x00' + b'\x00\x01\x00\x01'

        addr = (LOCALHOST, self.mitm_dns_port)
        client = BaseClient()
        transport, protocol = await asyncio.get_running_loop().create_datagram_endpoint(lambda: client, remote_addr=addr)
        while True:
            client.transport.sendto(query, addr)
            try:
                await asyncio.wait_for(client.recv(), timeout=0.1)
                break
            except TimeoutError:
                pass

        return proc

    def start_mitmproxy(self):
        if self.mitm is None:
            self.mitm = asyncio.create_task(self._start_mitmproxy())
        return self.mitm

    def mitmproxy_is_finished(self):
        return self.mitm and self.mitm.done() and self.mitm.result().returncode is not None

    async def main(self):
        if self.wg_conf.exists():
            pasta = await self.start_pasta()

            self.mitm_dns_port = get_free_port()
            self.mitm_wg_port = get_free_port()

            tasks = [
                asyncio.create_task(UdpServer((LOCALHOST, self.wg_port), (LOCALHOST, self.mitm_wg_port), self.start_mitmproxy).serve()),
                asyncio.create_task(UdpServer((LOCALHOST, self.dns_port), (LOCALHOST, self.mitm_dns_port), self.start_mitmproxy).serve()),
                asyncio.create_task(TcpServer((LOCALHOST, self.dns_port), (LOCALHOST, self.mitm_dns_port), self.start_mitmproxy).serve()),
            ]

        else:
            # launch mitmproxy first to create the wg config
            self.mitm_wg_port = self.wg_port
            self.mitm_dns_port = self.dns_port
            tasks = [
                asyncio.create_task(await self.start_mitmproxy()),
            ]
            while not self.wg_conf.exists() and not self.mitmproxy_is_finished():
                await asyncio.sleep(0.1)

            pasta = await self.start_pasta()

        rc = await pasta.wait()
        for t in tasks:
            t.cancel()
        return rc

async def main():
    args = []
    extras = None
    for arg in sys.argv[1:]:
        if extras is not None:
            extras.append(arg)
        elif arg == '--':
            extras = []
        elif not arg.startswith('--'):
            extras = [arg]
        else:
            args.append(arg)

    return await Handler(args, extras).main()


if __name__ == '__main__':
    sys.exit(asyncio.run(main()))
